# MaxxAgentFramework — environment variable template
#
# Copy this file to `.env` and fill in values for local development:
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows)
#
# Load in your app with:
#   from maxx_agent.settings import load_env_file
#   load_env_file()   # uses python-dotenv if installed
# Or read os.environ directly — see maxx_agent/settings.py
#
# Never commit `.env` — it is listed in `.gitignore`.

# -----------------------------------------------------------------------------
# Maxx / custom LLM HTTP endpoint (recommended for your own model)
# -----------------------------------------------------------------------------
MAXX_LLM_ENDPOINT_URL=http://localhost:8080/generate
MAXX_LLM_REQUEST_TIMEOUT_S=60
# Optional bearer token for your inference server:
# MAXX_LLM_API_KEY=

# -----------------------------------------------------------------------------
# OpenAI (optional — requires: pip install -e ".[openai]")
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# -----------------------------------------------------------------------------
# Hugging Face Inference API (optional)
# -----------------------------------------------------------------------------
# HF_API_TOKEN=hf_...
# HF_MODEL_ID=meta-llama/Llama-3.2-3B-Instruct

# -----------------------------------------------------------------------------
# Tools
# -----------------------------------------------------------------------------
# Directory for file_ops / read_file / write_file / sandbox cwd
MAXX_WORKSPACE_ROOT=.

# Enable dangerous tools only in trusted environments (true/false)
MAXX_ALLOW_DANGEROUS_TOOLS=false
MAXX_ENABLE_CODE_EXECUTION=false

# web_search (built-in and advanced) — your search proxy URL
# MAXX_WEB_SEARCH_ENDPOINT_URL=https://your-search-proxy.example/search

# -----------------------------------------------------------------------------
# Agent defaults (optional)
# -----------------------------------------------------------------------------
# MAXX_MAX_STEPS=10
# MAXX_TEMPERATURE=0.2
# MAXX_MEMORY_WINDOW_SIZE=5
